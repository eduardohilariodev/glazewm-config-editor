{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for GlazeWM Editor",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.glzr/glazewm/**" },
        { "path": "**/*.yaml" },
        { "path": "**/*.yml" }
      ]
    },
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}

